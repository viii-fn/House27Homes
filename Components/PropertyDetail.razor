<div class="drawer-wrapper @(_isOpen ? "slide" : "")">
    <div class="drawer-mask"></div>
    <div class="drawer">
        @if (_activeProperty is not null)
        {
            <div class="property-card">
                <div class="image">
                    <button class="like"></button>
                </div>
                <div class="description">
                    <div class="property-name">
                        <h2>@_activeProperty.Name</h2>
                    </div>
                    
                    <div class="property-location">
                        <p>@_activeProperty.Location</p>
                    </div>
                    
                    <div class="property-rating">
                        <div class="price">
                            <p><strong>@_activeProperty.Price</strong></p>
                        </div>
                        
                        <div class="review">&starf; @_activeProperty.Review</div>
                    </div>

                    <div class="property-location">
                        <p>@_activeProperty.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _isOpen;
    private DetailedProperties? _activeProperty;

    [Parameter, EditorRequired]
    public DetailedProperties? Property { get; set; }
    
    protected override void OnParametersSet()
    {
        if (Property != null)
        {
            _activeProperty = Property;
            _isOpen = true;
        }
    }

    private void Close()
    {
        _activeProperty = null;
        _isOpen = false;
    }
}