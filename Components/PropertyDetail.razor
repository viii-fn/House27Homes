<div class="drawer-mask @(_open ? "open" : "")">
    <div class="drawer">
        <div class="property-card">
            <div class="image"></div>
            <div class="description">
                <div class="property-name">
                    <h2>@_activeProperty.Name</h2>
                </div>
                
                <div class="property-location">
                    <p>@_activeProperty.Location</p>
                </div>

                <div class="property-location">
                    <p>@_activeProperty.Description</p>
                </div>

                <div class="property-location">
                    <p>
                        Number Of Rooms: <strong>@_activeProperty.Rooms</strong>
                    </p>
                </div>

                <div class="property-rating">
                    <div class="digits">
                        <p><strong>@_activeProperty.Price k</strong>/night</p>
                    </div>

                    <div class="digits">
                        <div class="digits">&starf; @_activeProperty.Review</div>
                    </div>
                </div>

                <div class="property-rating">
                    <button class="wide-button" @onclick="Close">Close</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _open;

    private Properties? _activeProperty;

    [Parameter, EditorRequired]
    public Properties Properties { get; set; }

    protected override void OnParametersSet()
    {
        if (Properties != null)
        {
            _activeProperty = Properties;
            _open = true;
        }
    }

    private void Close()
    {
        Properties = null;
        _open = false;
    }
}