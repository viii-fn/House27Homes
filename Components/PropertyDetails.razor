<div class="drawer-wrapper @(_isOpen ? "slide" : "")">
    <div class="drawer-mask"></div>
    <div class="drawer">
        @if (_activeProperty is not null)
        {
            <div class="drawer-content">
                <div class="description">
                    <div class="property-name">
                        <h2>@_activeProperty.Name</h2>
                    </div>

                    <div class="property-location">
                        <p>@_activeProperty.Location</p>
                    </div>

                    <div class="property-rating">
                        <div class="price">
                            <p><strong>@_activeProperty.Price k</strong>/night</p>
                        </div>
            
                        <div class="review">&starf; @_activeProperty.Review</div>
                    </div>
                </div>
            </div>
            <div class="drawer-control">
                <button @onclick="Close">
                    Close
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool _isOpen;
    private Properties _activeProperty;

    [Parameter, EditorRequired]
    public Properties? Details { get; set; }

    protected override void OnParametersSet()
    {
        if (Details != null)
        {
            _activeProperty = Details;
            _isOpen = true;
        }
    }

    private void Close()
    {
        _activeProperty = null;
        _isOpen = false;
    }
}